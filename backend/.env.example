# ─────────────────────────────────────────────────────────────
# RadarJobs.co — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────
# Project URL from: Settings → API in the Supabase dashboard
SUPABASE_URL=https://your-project.supabase.co

# Public anon key (safe to expose in browser context)
SUPABASE_ANON_KEY=your-anon-key

# Service role key — KEEP SECRET. Bypasses RLS. Server-side only.
SUPABASE_SERVICE_KEY=your-service-role-key

# ── AI Providers ──────────────────────────────────────────────
# Google Gemini (free tier) — https://ai.google.dev
GEMINI_API_KEY=your-gemini-api-key

# Groq (free tier, fast inference) — https://console.groq.com
GROQ_API_KEY=your-groq-api-key

# OpenRouter (free models available) — https://openrouter.ai
OPENROUTER_API_KEY=your-openrouter-key

# ── Embeddings ────────────────────────────────────────────────
# Cohere (free tier: 1K calls/min) — https://dashboard.cohere.com
COHERE_API_KEY=your-cohere-api-key

# ── Email ─────────────────────────────────────────────────────
# Resend (free tier: 3,000 emails/month) — https://resend.com
RESEND_API_KEY=your-resend-api-key

# ── App Config ────────────────────────────────────────────────
# Frontend origin used for CORS. Use * to allow all (dev only).
FRONTEND_URL=https://radarjobs.co

# Port the uvicorn server listens on inside the container
PORT=8000
